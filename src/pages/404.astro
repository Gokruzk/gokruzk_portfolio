---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Page Not Found" lang="en">
  <Header lang="en" />
  
  <main class="error-container">
    <div class="error-content">
      <h1 class="error-code font-mono">404</h1>
      
      <div class="message-group">
        <h2 id="error-title" class="error-title">Page Not Found</h2>
        <p id="error-desc" class="error-desc font-mono">
          The requested system route could not be resolved.
        </p>
      </div>

      <div class="action-group">
        <a href="/" id="back-btn" class="solid-btn">
          Return to Core System
        </a>
      </div>
    </div>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .error-container {
    min-height: calc(100vh - 10rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--stack-lg) var(--gutter);
    background-color: var(--bg-primary);
  }

  .error-content {
    max-width: 480px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--stack-md);
  }

  .error-code {
    font-size: clamp(5rem, 12vw, 8rem);
    line-height: 1;
    font-weight: 800;
    margin: 0;
    background: linear-gradient(135deg, var(--primary), #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px var(--primary-light));
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.95; }
    50% { transform: scale(1.03); opacity: 1; }
  }

  .message-group {
    display: flex;
    flex-direction: column;
    gap: var(--stack-sm);
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .error-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    border-left: 2px solid var(--primary);
    padding-left: 0.75rem;
    text-align: left;
    background-color: var(--bg-secondary);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
  }

  .action-group {
    margin-top: var(--stack-sm);
    width: 100%;
  }

  #back-btn {
    display: inline-block;
    width: 100%;
    max-width: 260px;
  }
</style>

<script>
  // Client-side Localization & Path Integration
  document.addEventListener('DOMContentLoaded', () => {
    const isSpanish = window.location.pathname.startsWith('/es');
    
    // Translation Dictionary
    const content = {
      en: {
        docTitle: "404 - Page Not Found",
        title: "Page Not Found",
        desc: "The requested system route could not be resolved.",
        btn: "Return to Core System",
        href: "/"
      },
      es: {
        docTitle: "404 - Página No Encontrada",
        title: "Página No Encontrada",
        desc: "La ruta del sistema solicitada no pudo ser resuelta.",
        btn: "Regresar al Sistema Central",
        href: "/es"
      }
    };

    const t = isSpanish ? content.es : content.en;

    // Update Content
    const docTitle = document.querySelector('title');
    const errorTitle = document.getElementById('error-title');
    const errorDesc = document.getElementById('error-desc');
    const backBtn = document.getElementById('back-btn') as HTMLAnchorElement;

    if (docTitle) docTitle.textContent = t.docTitle;
    if (errorTitle) errorTitle.textContent = t.title;
    if (errorDesc) errorDesc.textContent = t.desc;
    if (backBtn) {
      backBtn.textContent = t.btn;
      backBtn.href = t.href;
    }
  });
</script>
