---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'es';
}

const { title, description = "SYSTEM_ARCHITECT - Professional Full-Stack Developer Portfolio specializing in scalable systems, clean design, and technical precision.", lang = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <style is:inline>
      /* Hide page body during scroll restoration to eliminate jumping/flickering */
      html.js-scroll-restoring body {
        visibility: hidden !important;
      }

      /* Global Loader Styles - Inline to load instantly and avoid white flash */
      .global-loader {
        position: fixed;
        inset: 0;
        background-color: #0b0f19; /* Default to dark navy color to prevent blinding flashes */
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.4s ease, visibility 0.4s;
        visibility: visible;
        opacity: 1;
      }

      html.light .global-loader {
        background-color: #ffffff;
      }

      .global-loader.fade-out {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .loader-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }

      .loader-logo {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 70px;
        height: 70px;
        background-color: rgba(34, 197, 94, 0.05);
        border: 1px solid rgba(34, 197, 94, 0.2);
        border-radius: 50%;
        animation: pulse-glow 2s infinite;
      }

      .loader-icon {
        font-size: 2.25rem !important;
        color: #22c55e;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .loader-spinner {
        width: 32px;
        height: 32px;
        border: 2px solid rgba(34, 197, 94, 0.1);
        border-top: 2px solid #22c55e;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }

      .loader-text {
        font-size: 0.8rem;
        color: #9ca3af;
        letter-spacing: 0.08em;
        font-weight: 500;
        text-transform: uppercase;
      }

      html.light .loader-text {
        color: #4b5563;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      @keyframes pulse-glow {
        0%, 100% {
          transform: scale(1);
          box-shadow: 0 0 0 rgba(34, 197, 94, 0);
        }
        50% {
          transform: scale(1.05);
          box-shadow: 0 0 15px rgba(34, 197, 94, 0.15);
        }
      }
    </style>

    <script is:inline>
      if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('scrollPosition') !== null) {
        document.documentElement.classList.add('js-scroll-restoring');
      }

      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body>
    <!-- Global Loader Overlay -->
    <div id="global-loader" class="global-loader">
      <div class="loader-content">
        <div class="loader-spinner"></div>
      </div>
    </div>

    <slot />
    
    <script>
      // Header scroll background modification using classes
      const header = document.querySelector('header');
      if (header) {
        const toggleScrolled = () => {
          if (window.scrollY > 50) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        };
        
        // Initial check on load
        toggleScrolled();
        
        // Listen on scroll
        window.addEventListener('scroll', toggleScrolled);
      }
    </script>

    <script>
      // Global Page Loader Fade-Out Controller
      const hideLoader = () => {
        const loader = document.getElementById('global-loader');
        if (loader) {
          loader.classList.add('fade-out');
        }
      };

      if (document.readyState === 'complete') {
        hideLoader();
      } else {
        window.addEventListener('load', hideLoader);
        // Safety timeout to prevent infinite loader loop
        setTimeout(hideLoader, 2500);
      }
    </script>
  </body>
</html>
