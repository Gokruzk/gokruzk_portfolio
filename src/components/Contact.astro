---
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang];
---
<section class="contact-section" id="contact">
  <div class="container contact-container">
    <div class="contact-info">
      <h2 class="section-title">{t.contact_title}</h2>
      <p class="section-subtitle">
        {t.contact_subtitle}
      </p>
      
      <div class="info-list">
        <div class="info-item">
          <span class="material-symbols-outlined info-icon">alternate_email</span>
          <span class="info-value">nigelljama@gmail.com</span>
        </div>
        <div class="info-item">
          <span class="material-symbols-outlined info-icon">location_on</span>
          <span class="info-value">{t.contact_location}</span>
        </div>
      </div>
      
      <div class="social-links">
        <a target="_blank" href="https://github.com/Gokruzk" class="social-btn" aria-label="GitHub">
          <svg class="social-svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
        </a>
        <a target="_blank" href="https://www.linkedin.com/in/nigell-jama/" class="social-btn" aria-label="LinkedIn">
          <svg class="social-svg" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
        </a>
      </div>
    </div>
    
    
  </div>
</section>

<style>
  .contact-section {
    padding: var(--section-gap) 0;
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: var(--stack-sm);
    letter-spacing: -0.01em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: var(--stack-lg);
    line-height: 1.6;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: var(--stack-md);
    margin-bottom: var(--stack-lg);
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: var(--stack-md);
  }

  .info-icon {
    color: var(--primary);
  }

  .info-value {
    font-family: var(--font-mono);
    font-size: 0.937rem;
    color: var(--text-primary);
  }

  .social-links {
    display: flex;
    gap: var(--stack-sm);
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  .social-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
    background-color: var(--primary-light);
  }

  .social-svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .contact-form {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: var(--stack-lg);
  }

  .form-group {
    margin-bottom: var(--stack-md);
  }

  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: var(--stack-sm);
  }

  .form-input {
    width: 100%;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    outline: none;
    transition: all var(--transition-fast);
  }

  .form-input:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 1px var(--border-focus);
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .submit-btn {
    width: 100%;
    padding: 1rem;
  }

  @media (min-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
